// ═══════════════════════════════════════════════════════════
// MyGrind — firestore.rules (production lockdown)
// ───────────────────────────────────────────────────────────
// Mirror of the live rules at:
// https://console.firebase.google.com/project/my-grind-b8486/firestore/rules
//
// Version-controlled here so changes get diff'd in PR review,
// can't drift silently, and can be redeployed via firebase CLI
// if the Console rules get accidentally weakened.
//
// To update the live rules from this file (after editing here):
//   1. Install: npm install -g firebase-tools
//   2. Authenticate: firebase login
//   3. Initialize once: firebase init firestore (use this file)
//   4. Deploy: firebase deploy --only firestore:rules
//
// Until the CLI is wired up, the source of truth is still the
// Firebase Console — but any change made there should be mirrored
// back into this file in the same PR.
//
// ─── SECURITY REVIEW (2026-05-27) ──────────────────────────
// Current rules enforce per-user lockdown on /users/{userId},
// its /entries subcollection, AND the new /managedMinors
// subcollection used by the Phase 3 COPPA parent-managed path.
// All require Auth + uid match against the parent doc.
//
// IMPORTANT: This file is the SOURCE OF TRUTH version-controlled
// in the repo, but the live rules still live in the Firebase
// Console until the firebase CLI is wired up. After committing
// any change here, mirror the same change in the Console at
// https://console.firebase.google.com/project/my-grind-b8486/firestore/rules
// or rules drift will silently re-expose data.
//
// FOLLOW-UP ITEMS (not changes — flags for future work):
// 1. Consider field-level validation (e.g., size caps on entries,
//    schema validation on writes) once write abuse becomes a
//    real risk. Not needed at current scale.
// 2. If an /admin/ collection is ever added (server-side writes
//    only), explicitly deny client writes with:
//      match /admin/{document=**} {
//        allow read, write: if false;
//      }
//    Default-deny covers this implicitly today, but explicit is
//    safer once the collection name is in play.
// ═══════════════════════════════════════════════════════════

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      match /entries/{entryId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // COPPA managed-minor profiles. Only the parent (whose uid matches
      // the parent doc) can read or write their child's profile docs and
      // the child's journal entries. No cross-account read path exists.
      match /managedMinors/{minorId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;

        match /entries/{entryId} {
          allow read, write: if request.auth != null && request.auth.uid == userId;
        }
      }
    }
  }
}
